# XaviaApp - Variables de entorno
# Copiá este archivo como .env.local y completalo con tus valores reales.
# NO subas el .env.local a GitHub (está en .gitignore).

# === Google Sheets ===
# El ID de tu archivo de Google Sheets (lo sacás de la URL del Sheet)
# Ejemplo: si la URL es https://docs.google.com/spreadsheets/d/1AbC123XyZ.../edit
# entonces GOOGLE_SHEET_ID=1AbC123XyZ...
GOOGLE_SHEET_ID=

# Email del Service Account de Google Cloud (lo creás en console.cloud.google.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key del Service Account (incluí los \n literales)
# Ejemplo: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# === Sesiones ===
# Una clave secreta de al menos 32 caracteres para firmar las cookies de sesión.
# Generala con: openssl rand -base64 32
# o https://generate-secret.vercel.app/32
SESSION_SECRET=
